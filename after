from pyspark.sql import SparkSession

# 1. Initialize Spark (We need SparkContext for RDDs)
spark = SparkSession.builder.appName("LogAnalysis").getOrCreate()
sc = spark.sparkContext 

# 2. Read text file into an RDD
log_rdd = sc.textFile("hdfs:///user/data/weblogs.txt")

# 3. Extract HTTP Status Codes and count them
# Map creates a tuple (status_code, 1), reduceByKey adds the 1s together
status_counts = log_rdd.map(lambda line: (line.split(" ")[-2], 1)) \
                       .reduceByKey(lambda a, b: a + b)

# 4. Find most common IPs
ip_counts = log_rdd.map(lambda line: (line.split(" ")[0], 1)) \
                   .reduceByKey(lambda a, b: a + b)

# 5. Filter out error logs (4xx and 5xx) and count them
error_logs = log_rdd.filter(lambda line: line.split(" ")[-2].startswith('4') or \
                                         line.split(" ")[-2].startswith('5'))
error_count = error_logs.count()

# 6. Write back to HDFS (This creates a folder with part files)
status_counts.saveAsTextFile("hdfs:///user/data/status_output")
