Exercise 1: Web Server Logs
a) Create table and Load:

SQL
CREATE TABLE weblogs (url STRING, log_date STRING, log_time STRING, status_code INT)
ROW FORMAT DELIMITED FIELDS TERMINATED BY ',';

LOAD DATA INPATH 'hdfs:///user/data/weblogs.csv' INTO TABLE weblogs;
b) Most Visited URLs:

SQL
SELECT url, COUNT(*) as visits FROM weblogs GROUP BY url ORDER BY visits DESC LIMIT 5;
c) Peak Traffic Hours (Assuming log_time is 'HH:MM:SS'):

SQL
SELECT hour(log_time) as hr, COUNT(*) as traffic FROM weblogs GROUP BY hour(log_time) ORDER BY traffic DESC LIMIT 1;
d) Find 404 Errors:

SQL
SELECT * FROM weblogs WHERE status_code = 404;
e) Partitioned Table by Date (Learn this flow!):

SQL
-- 1. Enable dynamic partitioning
SET hive.exec.dynamic.partition=true;
SET hive.exec.dynamic.partition.mode=nonstrict;

-- 2. Create the partitioned table (Notice log_date is inside PARTITIONED BY, not the main columns)
CREATE TABLE weblogs_part (url STRING, log_time STRING, status_code INT)
PARTITIONED BY (log_date STRING)
ROW FORMAT DELIMITED FIELDS TERMINATED BY ',';

-- 3. Insert data dynamically (The partition column MUST be the last column in the SELECT)
INSERT INTO TABLE weblogs_part PARTITION(log_date)
SELECT url, log_time, status_code, log_date FROM weblogs;
f) Bucketed Table by Status Code:

SQL
-- Enable bucketing
SET hive.enforce.bucketing = true;

-- Create bucketed table
CREATE TABLE weblogs_bucket (url STRING, log_date STRING, log_time STRING, status_code INT)
CLUSTERED BY (status_code) INTO 4 BUCKETS
ROW FORMAT DELIMITED FIELDS TERMINATED BY ',';

-- Insert data
INSERT INTO TABLE weblogs_bucket SELECT * FROM weblogs;

-- Retrieve 404
SELECT * FROM weblogs_bucket WHERE status_code = 404;
