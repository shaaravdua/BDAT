from pyspark.sql import SparkSession

# Initialize a single SparkSession for all exercises
spark = SparkSession.builder \
    .appName("Week 10 Exercises") \
    .getOrCreate()

# ==============================================================================
# Exercise 1: Employee Analytics Using SparkSQL
# ==============================================================================
print("--- Exercise 1: Employee Analytics ---")

# a) Load employee data from HDFS
# Adjust the HDFS path to match your Hadoop setup (e.g., hdfs://localhost:9000/...)
emp_df = spark.read.csv("hdfs:///user/hadoop/employee_extended.csv", header=True, inferSchema=True)

# b) Create SparkSQL views
emp_df.createOrReplaceTempView("employees")

# c) Display highest salaried employee in each department
# Using a Window function to rank salaries within each department
highest_salary_df = spark.sql("""
    SELECT name, department, salary
    FROM (
        SELECT name, department, salary, 
               ROW_NUMBER() OVER (PARTITION BY department ORDER BY salary DESC) as rank
        FROM employees
    )
    WHERE rank = 1
""")
print("Highest Salaried Employee per Department:")
highest_salary_df.show()

# d) Perform gender-wise salary analysis
gender_analysis_df = spark.sql("""
    SELECT gender, 
           ROUND(AVG(salary), 2) as avg_salary, 
           MAX(salary) as max_salary, 
           MIN(salary) as min_salary
    FROM employees
    GROUP BY gender
""")
print("Gender-wise Salary Analysis:")
gender_analysis_df.show()

# e) Save SQL results back to HDFS
# Saving the gender analysis result as an example
gender_analysis_df.write.mode("overwrite").csv("hdfs:///user/hadoop/output/gender_analysis")
print("Saved gender analysis results to HDFS.\n")


# ==============================================================================
# Exercise 2: Sales Department Data Using SparkSQL
# ==============================================================================
print("--- Exercise 2: Sales Department Data ---")

# a) Load data into SparkSQL
sales_df = spark.read.csv("hdfs:///user/hadoop/sales_data.csv", header=True, inferSchema=True)
sales_df.createOrReplaceTempView("sales")

# b) Compute monthly total sales
# Assuming a 'date' column exists. DATE_FORMAT extracts the Year and Month.
monthly_sales_df = spark.sql("""
    SELECT DATE_FORMAT(date, 'yyyy-MM') as month, 
           ROUND(SUM(revenue), 2) as total_sales
    FROM sales
    GROUP BY DATE_FORMAT(date, 'yyyy-MM')
    ORDER BY month
""")
print("Monthly Total Sales:")
monthly_sales_df.show()

# c) Identify top 5 customers
top_customers_df = spark.sql("""
    SELECT customer_id, ROUND(SUM(revenue), 2) as total_spent
    FROM sales
    GROUP BY customer_id
    ORDER BY total_spent DESC
    LIMIT 5
""")
print("Top 5 Customers:")
top_customers_df.show()

# d) Calculate average revenue per product
avg_revenue_product_df = spark.sql("""
    SELECT product_id, ROUND(AVG(revenue), 2) as avg_revenue
    FROM sales
    GROUP BY product_id
    ORDER BY avg_revenue DESC
""")
print("Average Revenue per Product:")
avg_revenue_product_df.show()


# ==============================================================================
# Exercise 3: Department Insights
# ==============================================================================
print("--- Exercise 3: Department Insights ---")

# Note: Assuming you have a departments.csv. If not, replace this load with your actual method.
dept_df = spark.read.csv("hdfs:///user/hadoop/departments.csv", header=True, inferSchema=True)
dept_df.createOrReplaceTempView("departments")

# a) Join and display employee names with department names
# Assuming 'dept_id' is the common key in both tables
emp_dept_join_df = spark.sql("""
    SELECT e.name, d.department_name
    FROM employees e
    JOIN departments d ON e.dept_id = d.dept_id
""")
print("Employee Names with Department Names:")
emp_dept_join_df.show()

# b) Count employees in each department
dept_count_df = spark.sql("""
    SELECT d.department_name, COUNT(e.name) as employee_count
    FROM employees e
    JOIN departments d ON e.dept_id = d.dept_id
    GROUP BY d.department_name
""")
print("Employee Count per Department:")
dept_count_df.show()

# c) Find departments with avg salary > 60,000
high_avg_salary_dept_df = spark.sql("""
    SELECT d.department_name, ROUND(AVG(e.salary), 2) as avg_salary
    FROM employees e
    JOIN departments d ON e.dept_id = d.dept_id
    GROUP BY d.department_name
    HAVING AVG(e.salary) > 60000
""")
print("Departments with Average Salary > 60,000:")
high_avg_salary_dept_df.show()

# Stop the Spark session to free up resources
spark.stop()
